PORT=8765

# Neon Postgres connection string.
# Use the pooled URL from Neon for app traffic.
# Example shape:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=

# Set this before first startup to seed prototype accounts.
# The server stores only a salted hash in the database.
APP_SEED_PASSWORD=

# Set to true only when you want sample customer/operator accounts and demo listings.
APP_ENABLE_DEMO_DATA=false
